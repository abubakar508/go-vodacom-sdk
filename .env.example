# Required: application API key from the M-Pesa developer portal
MPESA_API_KEY=your-application-api-key

# Optional: sandbox or openapi
MPESA_ENVIRONMENT=sandbox

# Optional built-in markets:
#   vodacomDRC      -> DRC / USD
#   vodafoneGHA     -> GHA / GHS
#   vodacomTZN      -> TZN / TZS
#   vodacomLES      -> LES / LSL
#   vodacomMOZ      -> MOZ / MZN
MPESA_MARKET=vodacomDRC

# Optional custom/new market override if Vodacom adds markets before this SDK is updated
# MPESA_COUNTRY=DRC
# MPESA_CURRENCY=USD

# Optional but recommended: set this if Vodacom changes the platform public key
# or if your target environment provides a different key in the portal.
# If not set, SDK defaults are used for sandbox/openapi.
# MPESA_PUBLIC_KEY=

# Optional: must match your portal application origin where enforced
MPESA_ORIGIN=*

# Optional advanced overrides
# MPESA_HOST=openapi.m-pesa.com
# MPESA_PORT=443
